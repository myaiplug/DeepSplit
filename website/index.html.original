<!-- FEATURES -->
<section id="features">
  <div class="container">
    <p class="section-label">Built different</p>
    <h2>Everything you need.<br/>Nothing you don't.</h2>

    <div class="features-grid">
      <div class="feature-card fade-in">
        <div class="feature-icon" style="background:rgba(168,85,247,0.1)">🏠</div>
        <h3>100% Offline</h3>
        <p>Your music never leaves your machine. All AI processing runs locally using your CPU or GPU. No subscriptions, no usage limits, no data collection.</p>
      </div>
      <div class="feature-card fade-in">
        <div class="feature-icon" style="background:rgba(236,72,153,0.1)">🤖</div>
        <h3>SOTA AI Models</h3>
        <p>Powered by Kim_Vocal_2 (MDX-Net, SDR 10.18) for vocals and htdemucs_6s for instruments — the same models used by professional studios.</p>
      </div>
      <div class="feature-card fade-in">
        <div class="feature-icon" style="background:rgba(59,130,246,0.1)">⚡</div>
        <h3>GPU Auto-Detection</h3>
        <p>DeepSplit automatically detects your NVIDIA GPU and uses CUDA acceleration when available — up to 8× faster than CPU mode.</p>
      </div>
      <div class="feature-card fade-in">
        <div class="feature-icon" style="background:rgba(16,185,129,0.1)">🎛</div>
        <h3>Built-in Studio Mixer</h3>
        <p>Play, mute, solo and blend stems right in the app. Apply FX chains to individual tracks before exporting.</p>
      </div>
      <div class="feature-card fade-in">
        <div class="feature-icon" style="background:rgba(234,179,8,0.1)">🥁</div>
        <h3>Advanced DrumSep</h3>
        <p>Go beyond "drums" — isolate kick, snare, hi-hat and percussion as individual tracks. Perfect for sample creation.</p>
      </div>
      <div class="feature-card fade-in">
        <div class="feature-icon" style="background:rgba(249,115,22,0.1)">📁</div>
        <h3>All Formats</h3>
        <p>Accepts MP3, WAV, FLAC and M4A. Outputs clean normalized MP3 stems. Select any region of the track to process just what you need.</p>
      </div>
    </div>

    <!-- Tech pills -->
    <div class="tech-pills" style="margin-top:3rem">
      <p style="color:var(--muted);font-size:0.85rem;width:100%;margin-bottom:0.25rem">Powered by</p>
      <div class="pill"><div class="pill-dot" style="background:var(--purple)"></div>PyTorch 2.x</div>

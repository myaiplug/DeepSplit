<!-- HOW IT WORKS -->
<section id="how">
  <div class="container">
    <p class="section-label">Simple workflow</p>
    <h2>Up and running in<br/><em style="font-style:normal;background:linear-gradient(90deg,var(--purple),var(--pink));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">three steps.</em></h2>
    <p class="section-sub">No cloud required. All processing happens on your machine — your music never leaves your computer.</p>

    <div class="steps">
      <div class="step-card fade-in">
        <span class="step-num">01</span>
        <div class="step-icon">🎵</div>
        <h3>Drop your track</h3>
        <p>Upload any MP3, WAV, FLAC or M4A file. Select a region or use the entire track.</p>
      </div>
      <div class="step-card fade-in">
        <span class="step-num">02</span>
        <div class="step-icon">🎛</div>
        <h3>Choose your mode</h3>
        <p>Pick from 2-stem all the way up to 6-stem + advanced drum separation. GPU-optional.</p>
      </div>
      <div class="step-card fade-in">
        <span class="step-num">03</span>
        <div class="step-icon">⬇</div>
        <h3>Play & download</h3>
        <p>Stems are ready individually — play them in the built-in mixer, apply FX, or export.</p>
      </div>
    </div>
  </div>
</section>


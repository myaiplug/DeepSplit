        <h3 style="font-size:0.95rem;margin-bottom:0.25rem">Works offline</h3>
        <p style="font-size:0.85rem;color:var(--muted)">After first model download (~600 MB), works with no internet.</p>
      </div>
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:1.5rem;text-align:left">
        <div style="font-size:1.5rem;margin-bottom:0.5rem">♾</div>
        <h3 style="font-size:0.95rem;margin-bottom:0.25rem">Unlimited processing</h3>
        <p style="font-size:0.85rem;color:var(--muted)">No track limits, no watermarks, no hidden fees.</p>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">DeepSplit<span>.AI</span></div>
  <p style="margin-bottom:1rem">Professional AI Audio Separation · Built with ❤️ &amp; PyTorch</p>
  <p><a href="#how">How it works</a> · <a href="#modes">Modes</a> · <a href="#features">Features</a> · <a href="#download">Download</a></p>
  <p style="margin-top:1.5rem;font-size:0.75rem;color:rgba(107,114,128,0.5)">© 2025 DeepSplit. Free &amp; open source.</p>
</footer>

<script>
  // ── Waveform demo animation ──
  const stems = [
    { label: 'VOCALS',  color: '#ec4899', heights: [0.9,0.7,0.95,0.6,0.85,0.4,0.7,0.9,0.5,0.8,0.6,0.95,0.7,0.5,0.85,0.4,0.9,0.65] },
    { label: 'DRUMS',   color: '#eab308', heights: [0.4,0.9,0.2,0.95,0.3,0.9,0.1,0.95,0.3,0.9,0.2,0.95,0.4,0.9,0.1,0.95,0.3,0.9] },
    { label: 'BASS',    color: '#3b82f6', heights: [0.6,0.55,0.65,0.5,0.7,0.6,0.55,0.65,0.6,0.5,0.7,0.55,0.65,0.6,0.5,0.7,0.6,0.55] },
    { label: 'GUITAR',  color: '#f97316', heights: [0.3,0.5,0.7,0.4,0.6,0.8,0.3,0.5,0.7,0.45,0.6,0.8,0.3,0.55,0.7,0.4,0.6,0.8] },
    { label: 'PIANO',   color: '#10b981', heights: [0.5,0.3,0.6,0.8,0.4,0.3,0.6,0.5,0.8,0.3,0.5,0.65,0.4,0.8,0.3,0.6,0.5,0.4] },
    { label: 'OTHER',   color: '#a855f7', heights: [0.4,0.45,0.35,0.5,0.4,0.45,0.35,0.5,0.4,0.45,0.35,0.5,0.4,0.45,0.35,0.5,0.4,0.45] },
  ];

  const container = document.getElementById('waveform-rows');
  stems.forEach((stem, si) => {
    const row = document.createElement('div');
    row.className = 'stem-row';
    const label = document.createElement('div');
    label.className = 'stem-label';
    label.style.color = stem.color;
    label.textContent = stem.label;
    const wave = document.createElement('div');
    wave.className = 'stem-wave';
    const bars = document.createElement('div');
    bars.className = 'stem-bars';
    stem.heights.forEach((h, i) => {
      const bar = document.createElement('div');
      bar.className = 'bar';
      bar.style.background = stem.color;
      bar.style.height = `${Math.round(h * 28)}px`;
      bar.style.animationDelay = `${(i * 0.08 + si * 0.15).toFixed(2)}s`;
      bar.style.animationDuration = `${(1.2 + Math.random() * 0.8).toFixed(2)}s`;
      bar.style.opacity = '0.8';
      bars.appendChild(bar);
    });
    wave.appendChild(bars);
    const vol = document.createElement('div');
    vol.className = 'stem-vol';
    vol.textContent = '-' + Math.round(Math.random()*6+2) + 'dB';
    row.appendChild(label);
    row.appendChild(wave);
    row.appendChild(vol);
    container.appendChild(row);
  });

  // ── Genre Demo Toggle ──
  function toggleDemo(btn, demoId) {
    const card = btn.closest('.genre-card');
    const buttons = card.querySelectorAll('.demo-btn');
    
    // Deactivate others
    buttons.forEach(b => b.classList.remove('active'));
    
    // Toggle active
    btn.classList.add('active');
    card.classList.add('playing');

    // Simulate audio loading/playing feedback
    console.log(`Playing demo: ${demoId}`);
    
    // In a real app, this would switch the <audio> source.
    // For now, we provide the UI feedback requested.
  }

  // ── Scroll fade-in ──
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DeepSplit AI — Professional Audio Stem Separation</title>
  <meta name="description" content="DeepSplit uses state-of-the-art AI to separate any song into individual stems — vocals, drums, bass, guitar, piano and more. Free desktop app for Windows." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple: #a855f7;
      --pink: #ec4899;
      --blue: #3b82f6;
      --green: #10b981;
      --bg: #050505;
      --surface: #0f0f0f;
      --border: rgba(255,255,255,0.08);
      --text: #f8fafc;
      --muted: #6b7280;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* ─── Noise texture overlay ─── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.4;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 2rem;
      background: rgba(5,5,5,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }
    .logo-icon {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, #a855f7, #ec4899);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 13px;
      color: white;
      box-shadow: 0 0 20px rgba(168,85,247,0.4);
    }
    .logo-text { font-size: 1.1rem; font-weight: 800; color: white; }
    .logo-text span { color: var(--purple); }
    nav ul { display: flex; gap: 2rem; list-style: none; }
    nav ul a { color: var(--muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s; }
    nav ul a:hover { color: white; }
    .nav-cta {
      background: linear-gradient(135deg, var(--purple), var(--pink));
      color: white;
      border: none;
      padding: 0.6rem 1.4rem;
      border-radius: 100px;
      font-size: 0.875rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 20px rgba(168,85,247,0.3);
    }
    .nav-cta:hover { transform: scale(1.05); box-shadow: 0 0 30px rgba(168,85,247,0.5); }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 4rem;
      position: relative;
    }
    .hero-glow-1 {
      position: absolute;
      top: 10%; left: 10%;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(168,85,247,0.15), transparent 70%);
      border-radius: 50%;
      animation: pulse 6s ease-in-out infinite;
    }
    .hero-glow-2 {
      position: absolute;
      bottom: 10%; right: 10%;
      width: 350px; height: 350px;
      background: radial-gradient(circle, rgba(236,72,153,0.12), transparent 70%);
      border-radius: 50%;
      animation: pulse 8s ease-in-out 2s infinite;
    }
    @keyframes pulse { 0%,100% { transform: scale(1); opacity:0.6; } 50% { transform: scale(1.1); opacity:1; } }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(168,85,247,0.1);
      border: 1px solid rgba(168,85,247,0.3);
      padding: 0.4rem 1rem;
      border-radius: 100px;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--purple);
      letter-spacing: 0.05em;
      margin-bottom: 2rem;
    }
    .hero-badge::before { content: '◉'; font-size: 0.6rem; animation: blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    h1 {
      font-size: clamp(3rem, 8vw, 6.5rem);
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #fff 0%, #c4b5fd 40%, #ec4899 80%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
    }
    .hero-sub {
      font-size: clamp(1.1rem, 2.5vw, 1.4rem);
      color: var(--muted);
      max-width: 680px;
      font-weight: 400;
      margin-bottom: 3rem;
    }

    /* ─── GENRE SHOWCASE ─── */
    .genre-section { padding: 8rem 2rem; background: rgba(168,85,247,0.02); }
    .genre-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2rem;
      margin-top: 4rem;
    }
    .genre-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    }
    .genre-card:hover { border-color: var(--purple); transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
    .genre-card h3 { font-size: 1.5rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.75rem; }
    .genre-tag { font-size: 0.7rem; font-family: 'JetBrains Mono', monospace; color: var(--muted); opacity: 0.8; }
    
    .demo-controls { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
    .demo-btn {
      width: 100%;
      padding: 1rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.03);
      color: white;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      transition: all 0.2s;
    }
    .demo-btn:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); }
    .demo-btn.active { background: var(--purple); border-color: var(--purple); box-shadow: 0 0 20px rgba(168,85,247,0.4); }
    
    .split-viz {
      height: 40px;
      display: flex;
      align-items: center;
      gap: 3px;
      margin-top: 1rem;
      opacity: 0.3;
      transition: opacity 0.3s;
    }
    .genre-card.playing .split-viz { opacity: 1; }
    .viz-bar { flex: 1; height: 4px; background: var(--purple); border-radius: 2px; }

    /* ─── COMPARISON ─── */
    .compare-section { padding: 8rem 2rem; }
    .compare-table {
      width: 100%;
      max-width: 900px;
      margin: 4rem auto 0;
      border-collapse: collapse;
      border: 1px solid var(--border);
      border-radius: 20px;
      overflow: hidden;
      background: var(--surface);
    }
    .compare-table th, .compare-table td { padding: 1.5rem; text-align: left; border-bottom: 1px solid var(--border); }
    .compare-table th { background: rgba(255,255,255,0.02); font-weight: 700; color: white; }
    .compare-table .feature-col { width: 40%; font-weight: 500; color: var(--muted); }
    .compare-table .check { color: var(--green); font-weight: 900; }
    .compare-table .cross { color: #ef4444; font-weight: 900; opacity: 0.5; }
    .highlight-row { background: rgba(168,85,247,0.05); }

    /* ─── PRICING ─── */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 4rem;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }
    .price-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 3rem;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
    }
    .price-card.pro { border-color: var(--purple); background: linear-gradient(180deg, rgba(168,85,247,0.05), transparent); position: relative; }
    .price-card.pro::after {
      content: 'BEST VALUE';
      position: absolute;
      top: 1.5rem; right: 1.5rem;
      font-size: 0.65rem; font-weight: 800; color: var(--purple);
      background: rgba(168,85,247,0.1); padding: 0.25rem 0.75rem; border-radius: 100px;
    }
    .price-tag { font-size: 3rem; font-weight: 900; margin: 1.5rem 0; }
    .price-tag span { font-size: 1rem; color: var(--muted); font-weight: 400; }
    .price-features { list-style: none; margin-bottom: 2.5rem; flex: 1; }
    .price-features li { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; font-size: 0.95rem; color: var(--muted); }
    .price-features li svg { color: var(--purple); flex-shrink: 0; }

    /* ─── SEO / FREE GAME ─── */
    .seo-section { padding: 8rem 2rem; background: rgba(5,5,5,0.5); }
    .article-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 4rem;
    }
    .article-card {
      padding: 2rem;
      border-radius: 20px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      transition: all 0.3s;
      cursor: pointer;
    }
    .article-card:hover { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); }
    .article-card h4 { font-size: 1.1rem; margin-bottom: 1rem; line-height: 1.4; }
    .article-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
    .read-more { display: flex; align-items: center; gap: 0.5rem; color: var(--purple); font-size: 0.8rem; font-weight: 700; margin-top: 1.5rem; }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 4rem;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: linear-gradient(135deg, var(--purple), var(--pink));
      color: white;
      padding: 1rem 2rem;
      border-radius: 14px;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 40px rgba(168,85,247,0.4);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 60px rgba(168,85,247,0.6); }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 1rem 2rem;
      border-radius: 14px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }

    /* Waveform visualizer */
    .waveform-demo {
      width: 100%;
      max-width: 800px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }
    .waveform-demo::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(168,85,247,0.05), transparent 60%);
    }
    .stem-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.75rem;
    }
    .stem-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      font-weight: 500;
      width: 80px;
      text-align: right;
      flex-shrink: 0;
    }
    .stem-wave {
      flex: 1;
      height: 32px;
      border-radius: 4px;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
    }
    .stem-bars {
      display: flex;
      gap: 2px;
      align-items: center;
      height: 100%;
      width: 100%;
    }
    .bar {
      width: 3px;
      border-radius: 2px;
      animation: wavebar 1.5s ease-in-out infinite alternate;
    }
    @keyframes wavebar { from { transform: scaleY(0.2); } to { transform: scaleY(1); } }

    .stem-vol { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--muted); width: 35px; }

    /* ─── SECTION COMMON ─── */
    section { padding: 6rem 2rem; position: relative; }
    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 1rem;
    }
    h2 {
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 1.25rem;
    }
    .section-sub { color: var(--muted); font-size: 1.1rem; max-width: 520px; }
    .container { max-width: 1100px; margin: 0 auto; }

    /* ─── HOW IT WORKS ─── */
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .step-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      position: relative;
      transition: border-color 0.3s, transform 0.3s;
    }
    .step-card:hover { border-color: rgba(168,85,247,0.4); transform: translateY(-4px); }
    .step-num {
      font-size: 0.75rem;
      font-weight: 700;
      font-family: 'JetBrains Mono', monospace;
      color: var(--purple);
      margin-bottom: 1rem;
      background: rgba(168,85,247,0.1);
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 100px;
    }
    .step-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .step-card h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.5rem; }
    .step-card p { color: var(--muted); font-size: 0.95rem; }

    /* ─── STEM MODES ─── */
    .modes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 3rem;
    }
    .mode-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.5rem;
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }
    .mode-card:hover { transform: translateY(-4px); }
    .mode-card.featured { border-color: rgba(168,85,247,0.4); background: rgba(168,85,247,0.05); }
    .mode-badge {
      position: absolute;
      top: 1rem; right: 1rem;
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--pink);
      background: rgba(236,72,153,0.15);
      border: 1px solid rgba(236,72,153,0.3);
      padding: 0.2rem 0.6rem;
      border-radius: 100px;
    }
    .mode-card .icon { font-size: 2rem; margin-bottom: 0.75rem; }
    .mode-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
    .mode-stems { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.75rem; }
    .stem-tag {
      font-size: 0.7rem;
      font-family: 'JetBrains Mono', monospace;
      padding: 0.2rem 0.5rem;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--muted);
    }
    .mode-time { font-size: 0.75rem; color: var(--muted); margin-top: 0.75rem; font-family: 'JetBrains Mono', monospace; }

    /* ─── FEATURES ─── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .feature-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2rem;
      transition: all 0.3s;
    }
    .feature-card:hover { border-color: rgba(168,85,247,0.3); transform: translateY(-2px); }
    .feature-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1.25rem;
    }
    .feature-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; }
    .feature-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.7; }

    /* ─── PROOF / STATS ─── */
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 20px;
      overflow: hidden;
      margin-top: 3rem;
    }
    .stat {
      background: var(--surface);
      padding: 2.5rem 2rem;
      text-align: center;
    }
    .stat-num {
      font-size: 3rem;
      font-weight: 900;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, var(--purple), var(--pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-label { color: var(--muted); font-size: 0.9rem; margin-top: 0.25rem; }
    .stat-sub { font-size: 0.75rem; color: rgba(107,114,128,0.7); margin-top: 0.25rem; font-family: 'JetBrains Mono', monospace; }

    /* ─── TECH STACK ─── */
    .tech-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 2rem;
    }
    .pill {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      padding: 0.5rem 1rem;
      border-radius: 100px;
      font-size: 0.85rem;
      font-weight: 500;
    }
    .pill-dot { width: 6px; height: 6px; border-radius: 50%; }

    /* ─── DOWNLOAD CTA ─── */
    .cta-section {
      text-align: center;
      padding: 8rem 2rem;
      position: relative;
    }
    .cta-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 50%, rgba(168,85,247,0.08), transparent 70%);
      pointer-events: none;
    }
    .cta-section h2 { margin-bottom: 1rem; }
    .cta-section p { color: var(--muted); font-size: 1.1rem; margin-bottom: 3rem; }
    .download-box {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .download-meta {
      font-size: 0.8rem;
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
    }

    /* ─── FOOTER ─── */
    footer {
      border-top: 1px solid var(--border);
      padding: 3rem 2rem;
      text-align: center;
      color: var(--muted);
      font-size: 0.875rem;
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: white; }
    .footer-logo { margin-bottom: 1rem; font-weight: 800; font-size: 1.25rem; }
    .footer-logo span { color: var(--purple); }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: rgba(168,85,247,0.3); border-radius: 3px; }

    /* ─── ANIMATIONS ─── */
    .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.7s, transform 0.7s; }
    .fade-in.visible { opacity: 1; transform: none; }

    @media (max-width: 768px) {
      nav ul { display: none; }
      h1 { font-size: 2.8rem; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="logo">
    <div class="logo-icon">DS</div>
    <span class="logo-text">DeepSplit<span>.AI</span></span>
  </a>
  <ul>
    <li><a href="#how">How it works</a></li>
    <li><a href="#demos">Benchmarks</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#download">Download</a></li>
  </ul>
  <a href="#download" class="nav-cta">⬇ Download Free</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow-1"></div>
  <div class="hero-glow-2"></div>

  <div class="hero-badge">STATE-OF-THE-ART AI · MDX + DEMUCS HYBRID</div>

  <h1>Stop Renting Stems.<br/><em style="font-style:normal;background:linear-gradient(90deg,var(--purple),#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Own the Source.</em></h1>
  <p class="hero-sub">
    The world's first professional AI stem separator that lives on your desktop. No cloud, no track limits, and zero subscriptions. Total privacy for your creative process.
  </p>

  <div class="hero-actions">
    <a href="#download" class="btn-primary" id="main-download-btn">
